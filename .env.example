# mailx-bridge configuration
# Copy to .env and fill in your values.

# Required: Your Mailx API access key (85 characters).
MAILX_ACCESS_KEY=

# Required: Email address that aliases forward to.
MAILX_RECIPIENT=you@example.com

# Required: Mailx domain to create aliases under (e.g. ambox.net).
MAILX_DOMAIN=

# Required: Bearer token that clients (Bitwarden) must present.
# Generate with: openssl rand -base64 48 | tr -d '=/+\n'
BRIDGE_API_KEY=

# Optional: Mailx API base URL (default: https://api.mailx.net/v1).
# MAILX_BASE_URL=https://api.mailx.net/v1

# Optional: Address to listen on (default: :8080).
# LISTEN_ADDR=:8080
